# Application
SECRET_KEY=your-secret-key-here

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=life_tracker_db
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# Frontend
FRONTEND_URL=http://localhost:3000

# Production domain (optional)
DOMAIN_URL=https://yourdomain.com

# Email (Flask-Mail) — required for welcome & password reset emails
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
# MAIL_DEFAULT_SENDER must exactly match MAIL_USERNAME for Outlook/Hotmail SMTP
MAIL_DEFAULT_SENDER=your-email@hotmail.com
